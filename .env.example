# OrderSuggest settings

# Server
HOST=127.0.0.1
PORT=7890
DEFAULT_RESTAURANT_NAME=預設餐廳

# School/OpenAI-compatible model API
# Example: https://api.example.edu/v1
API_BASE_URL=
API_KEY=
API_MODEL=vibe
VISION_MODEL=llama4scout
API_TEMPERATURE=0.7

# Optional model names for specific subtasks. Leave blank to use API_MODEL.
PREF_MODEL=
CLASSIFY_MODEL=

# Feature flags
USE_LLM_EXTRACTION=false
USE_LLM_CLASSIFICATION=false

# Ollama fallback only. Used when API_BASE_URL or API_KEY is empty.
OLLAMA_MODEL=gemma3:12b
